// BL-03: re-pointed from a GroundAoe damage pulse to a difficult-terrain slow ZONE.
// Heavier gravity = a persistent field that halves enemy move-speed (DifficultTerrain,
// strength 0.5), negated by FreedomOfMovement. Centered on the caster for v1.
BasicAura(
    buildup_duration: 0.5,
    cast_duration: 0.6,
    recover_duration: 0.35,
    targets: OutOfGroup,
    auras: [
        (
            kind: DifficultTerrain,
            strength: 0.5,
            duration: Some(2),
            category: Magical,
        ),
    ],
    aura_duration: Some(8.0),
    range: 6.0,
    energy_cost: 70.0,
    scales_with_combo: false,
    specifier: None,
    meta: (school: Some(Axiomancy), subschool: Some(Gravimancy), form: Some(Transmutation), source: Some(Arcane), cooldown: Some(16.0)),
)
