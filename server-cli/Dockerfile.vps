# syntax=docker/dockerfile:1
# Multi-stage build for VPS deployment (x86_64 Linux)
# Uses BuildKit cache mounts for fast incremental rebuilds (~2-5 min after first build)

# Stage 1: Compile
FROM rust:slim-bookworm AS builder

ENV VELOREN_USERDATA_STRATEGY=executable \
    CARGO_NET_GIT_FETCH_WITH_CLI=true

# System deps — cached unless this layer changes
RUN apt-get update && apt-get install -y \
    binutils \
    pkg-config \
    build-essential \
    git \
    mold \
    clang \
    && rm -rf /var/lib/apt/lists/*

# Rust toolchain — cached unless nightly version changes
RUN rustup toolchain install nightly-2025-09-08 \
    && rustup default nightly-2025-09-08

WORKDIR /src
COPY . .

# GIT_VERSION goes here (after COPY) so apt/rustup layers stay cached
ARG GIT_VERSION="0/0"
ENV VELOREN_GIT_VERSION=${GIT_VERSION}

# BuildKit cache mounts:
#   /usr/local/cargo/registry  — crate downloads (persists on VPS between builds)
#   /src/target                — incremental compile artifacts (persists on VPS)
RUN --mount=type=cache,target=/usr/local/cargo/registry \
    --mount=type=cache,target=/src/target \
    cargo build --release \
        --no-default-features \
        --features default-publish \
        -p veloren-server-cli \
    && cp target/release/veloren-server-cli /tmp/veloren-server-cli \
    && objcopy --compress-debug-sections=zlib \
        /tmp/veloren-server-cli \
        /tmp/veloren-server-cli-compressed \
    && mv /tmp/veloren-server-cli-compressed /tmp/veloren-server-cli

# Stage 2: Minimal runtime image
FROM debian:stable-slim

LABEL com.centurylinklabs.watchtower.stop-signal="SIGUSR1"

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        libgcc-s1 \
        iproute2 \
        net-tools \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /tmp/veloren-server-cli /opt/veloren-server-cli
COPY --from=builder /src/assets/common       /opt/assets/common
COPY --from=builder /src/assets/server       /opt/assets/server
COPY --from=builder /src/assets/world        /opt/assets/world

WORKDIR /opt
ENV RUST_BACKTRACE=full
ENTRYPOINT ["/opt/veloren-server-cli"]
